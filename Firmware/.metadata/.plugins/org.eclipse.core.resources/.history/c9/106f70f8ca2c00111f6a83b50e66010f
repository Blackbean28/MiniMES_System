/**
  * @brief  Function implementing the SensorTask thread.
  * @param  argument: Not used
  * @retval None
  */
/* USER CODE END Header_StartSensorTask */
void StartSensorTask(void const * argument)
{
  /* USER CODE BEGIN 5 */
  /* Infinite loop */
	/* USER CODE BEGIN StartSensorTask */
	  CAN_TxHeaderTypeDef TxHeader;
	  uint8_t TxData[8];
	  uint32_t TxMailbox;

	  TxHeader.StdId = MY_CAN_ID; // 매크로에 의해 0x010 또는 0x020으로 자동 세팅됨
	  TxHeader.RTR = CAN_RTR_DATA;
	  TxHeader.IDE = CAN_ID_STD;
	  TxHeader.DLC = 8;

	  /* Infinite loop */
	  for(;;)
	  {
	    // 1. 상태가 에러(0x02)가 아닐 때만 정상적으로 공정이 돌아가며 데이터가 변동됨
	    if(currentStatus != 0x02) {
	        currentTemp = (rand() % 5) + 60;        // 60~64도
	        currentRpm = 3000 + (rand() % 100);     // 3000~3099 RPM
	        currentCurrent = 1200 + (rand() % 50);  // 1200~1249 mA
	        currentCount++;
	    }

	    // 2. 8바이트 CAN 페이로드 조립 (리틀 엔디안)
	    TxData[0] = currentStatus;
	    TxData[1] = currentTemp;
	    TxData[2] = (uint8_t)(currentRpm & 0xFF);
	    TxData[3] = (uint8_t)((currentRpm >> 8) & 0xFF);
	    TxData[4] = (uint8_t)(currentCurrent & 0xFF);
	    TxData[5] = (uint8_t)((currentCurrent >> 8) & 0xFF);
	    TxData[6] = currentCount;
	    TxData[7] = 0x00;

	    // 3. CAN 버스 송출
	    HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox);

	    // 500ms 주기 (RTOS 스케줄러 휴식)
	    osDelay(500);
	  }
